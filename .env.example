# Google Maps Platform keys
# Recommended: create one restricted key and use it for all services below.
# Enabled APIs: Maps JavaScript API, Places API, Directions API, Geocoding API

# Shared server key (recommended)
GOOGLE_MAPS_API_KEY=your_google_maps_platform_server_key

# Optional overrides (leave empty if using GOOGLE_MAPS_API_KEY)
GOOGLE_PLACES_API_KEY=
GOOGLE_DIRECTIONS_API_KEY=
GOOGLE_GEOCODING_API_KEY=

# Client key for Google Maps JavaScript SDK
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_javascript_key

# Optional client overrides
VITE_GOOGLE_PLACES_API_KEY=
VITE_GOOGLE_DIRECTIONS_API_KEY=
VITE_GOOGLE_GEOCODING_API_KEY=

# Server Configuration
DATABASE_URL=your_postgres_connection_string
JWT_SECRET=your_jwt_secret_key
